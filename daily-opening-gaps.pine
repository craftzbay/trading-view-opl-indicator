//@version=6
indicator("Opening Levels — Gaps + OPL", "OL", overlay=true,
          max_lines_count=500, max_boxes_count=500, max_labels_count=100)

// ============================================================
//  Inputs: General
// ============================================================
gGen = "General"
tzInput = input.string("America/New_York", "Timezone", group=gGen, options=[
     "Exchange",
     "UTC",
     "America/New_York",
     "America/Chicago",
     "America/Denver",
     "America/Los_Angeles",
     "Europe/London",
     "Europe/Berlin",
     "Europe/Moscow",
     "Asia/Dubai",
     "Asia/Kolkata",
     "Asia/Shanghai",
     "Asia/Hong_Kong",
     "Asia/Singapore",
     "Asia/Tokyo",
     "Asia/Ulaanbaatar",
     "Australia/Sydney"],
     tooltip="OPL-ийн open цаг болон HTF gap-ийн өдөр/долоо хоног/сарын хил энэ timezone-оор тооцогдоно. 'Exchange' = графикийн symbol-ийн биржийн timezone.")

// ============================================================
//  Inputs: HTF Opening Gaps
// ============================================================
gHtf = "HTF Opening Gaps"

showMonthly    = input.bool(true,        "", inline="gm", group=gHtf, tooltip="Monthly Opening Gap (previous month close → current month open)")
monthlyName    = input.string("MONTHLY", "", inline="gm", group=gHtf)
monthlyColor   = input.color(#4a148c,    "", inline="gm", group=gHtf)
monthlyStyleIn = input.string("Solid",   "", options=["Solid","Dashed","Dotted"], inline="gm", group=gHtf)
monthlyWidthIn = input.string("1px",     "", options=["1px","2px","3px","4px"],   inline="gm", group=gHtf)

showWeekly     = input.bool(true,        "", inline="gw", group=gHtf, tooltip="Weekly Opening Gap (previous week close → current week open)")
weeklyName     = input.string("WEEKLY",  "", inline="gw", group=gHtf)
weeklyColor    = input.color(#0c3299,    "", inline="gw", group=gHtf)
weeklyStyleIn  = input.string("Solid",   "", options=["Solid","Dashed","Dotted"], inline="gw", group=gHtf)
weeklyWidthIn  = input.string("1px",     "", options=["1px","2px","3px","4px"],   inline="gw", group=gHtf)

showDaily      = input.bool(true,        "", inline="gd", group=gHtf, tooltip="Daily Opening Gap (previous day close → current day open)")
dailyName      = input.string("DAILY",   "", inline="gd", group=gHtf)
dailyColor     = input.color(#006064,    "", inline="gd", group=gHtf)
dailyStyleIn   = input.string("Solid",   "", options=["Solid","Dashed","Dotted"], inline="gd", group=gHtf)
dailyWidthIn   = input.string("1px",     "", options=["1px","2px","3px","4px"],   inline="gd", group=gHtf)

// ============================================================
//  Inputs: Opening Price Lines  (one row each: show | label | color | style | width)
// ============================================================
gOpl = "Opening Price Lines"

mShow = input.bool(true,    "", inline="m", group=gOpl, tooltip="00:00 — Midnight open")
mTag  = input.string("00:00","", inline="m", group=gOpl)
mCol  = input.color(#0c3299,"", inline="m", group=gOpl)
mSty  = input.string("Solid","", options=["Solid","Dashed","Dotted"], inline="m", group=gOpl)
mWid  = input.string("1px",  "", options=["1px","2px","3px","4px","5px"], inline="m", group=gOpl)

nShow = input.bool(true,    "", inline="n", group=gOpl, tooltip="08:30 — New York open")
nTag  = input.string("08:30","", inline="n", group=gOpl)
nCol  = input.color(#0c3299,"", inline="n", group=gOpl)
nSty  = input.string("Solid","", options=["Solid","Dashed","Dotted"], inline="n", group=gOpl)
nWid  = input.string("1px",  "", options=["1px","2px","3px","4px","5px"], inline="n", group=gOpl)

eShow = input.bool(true,    "", inline="e", group=gOpl, tooltip="09:30 — Equities open")
eTag  = input.string("09:30","", inline="e", group=gOpl)
eCol  = input.color(#0c3299,"", inline="e", group=gOpl)
eSty  = input.string("Solid","", options=["Solid","Dashed","Dotted"], inline="e", group=gOpl)
eWid  = input.string("1px",  "", options=["1px","2px","3px","4px","5px"], inline="e", group=gOpl)

aShow = input.bool(false,   "", inline="a", group=gOpl, tooltip="13:30 — Afternoon open")
aTag  = input.string("01:30","", inline="a", group=gOpl)
aCol  = input.color(#0c3299,"", inline="a", group=gOpl)
aSty  = input.string("Solid","", options=["Solid","Dashed","Dotted"], inline="a", group=gOpl)
aWid  = input.string("1px",  "", options=["1px","2px","3px","4px","5px"], inline="a", group=gOpl)

// ============================================================
//  Inputs: Notes (top center)
// ============================================================
gNotes     = "Notes"
showTitle  = input.bool(true,         "", inline="t", group=gNotes)
titleText  = input.string("Title",    "", inline="t", group=gNotes)
titleColor = input.color(#000000,     "", inline="t", group=gNotes)
showSub    = input.bool(true,         "", inline="s", group=gNotes)
subText    = input.string("Subtitle", "", inline="s", group=gNotes)
subColor   = input.color(#000000,     "", inline="s", group=gNotes)

// ============================================================
//  Inputs: Setup Checklist (top right)
// ============================================================
gSetup    = "Setup Checklist"
showSetup = input.bool(true, "Show checklist", group=gSetup)

c1On = input.bool(false,               "", inline="c1", group=gSetup)
c1Tx = input.string("Bias confirmed",  "", inline="c1", group=gSetup)
c2On = input.bool(false,               "", inline="c2", group=gSetup)
c2Tx = input.string("Liquidity taken", "", inline="c2", group=gSetup)
c3On = input.bool(false,               "", inline="c3", group=gSetup)
c3Tx = input.string("FVG aligned",     "", inline="c3", group=gSetup)
c4On = input.bool(false,               "", inline="c4", group=gSetup)
c4Tx = input.string("Entry confirmed", "", inline="c4", group=gSetup)
c5On = input.bool(false,               "", inline="c5", group=gSetup)
c5Tx = input.string("Risk OK",         "", inline="c5", group=gSetup)

// ============================================================
//  Helpers
// ============================================================
toLineStyle(string s) => s == "Dashed" ? line.style_dashed : s == "Dotted" ? line.style_dotted : line.style_solid
toWidth(string s)     => s == "5px" ? 5 : s == "4px" ? 4 : s == "3px" ? 3 : s == "2px" ? 2 : 1

// ============================================================
//  Time / timezone
// ============================================================
Timezone = tzInput == "Exchange" ? syminfo.timezone : tzInput
intraday = timeframe.isintraday and timeframe.multiplier <= 31

isNewDay   = ta.change(time("1D")) != 0
isNewWeek  = ta.change(time("1W")) != 0
isNewMonth = ta.change(time("1M")) != 0

// ============================================================
//  HTF Opening Gaps
//  Each gap = 2 rays (top/bottom) + a 90%-transparent zone box.
//  Daily gaps accumulate through the week (reset weekly); weekly &
//  monthly keep only the current period.
//  Priority on overlap: MONTHLY > WEEKLY > DAILY.
// ============================================================
clearGaps(array<line> rays, array<box> zones) =>
    for r in rays
        line.delete(r)
    for b in zones
        box.delete(b)
    array.clear(rays)
    array.clear(zones)

drawGap(float prevClose, float openPx, color col, int wid, string sty, array<line> rays, array<box> zones) =>
    if prevClose != openPx
        top = math.max(prevClose, openPx)
        bot = math.min(prevClose, openPx)
        array.push(rays, line.new(bar_index, top, bar_index + 1, top, extend=extend.right, color=col, width=wid, style=sty))
        array.push(rays, line.new(bar_index, bot, bar_index + 1, bot, extend=extend.right, color=col, width=wid, style=sty))
        array.push(zones, box.new(bar_index, top, bar_index + 1, bot, extend=extend.right, bgcolor=color.new(col, 90), border_color=na))

var array<line> dailyRays    = array.new<line>()
var array<box>  dailyZones   = array.new<box>()
var array<line> weeklyRays   = array.new<line>()
var array<box>  weeklyZones  = array.new<box>()
var array<line> monthlyRays  = array.new<line>()
var array<box>  monthlyZones = array.new<box>()

monthlyFiring = showMonthly and isNewMonth
weeklyFiring  = showWeekly  and isNewWeek

if isNewWeek
    clearGaps(dailyRays, dailyZones)
if showDaily and isNewDay and not weeklyFiring and not monthlyFiring and not na(close[1])
    drawGap(close[1], open, dailyColor, toWidth(dailyWidthIn), toLineStyle(dailyStyleIn), dailyRays, dailyZones)

if isNewWeek
    clearGaps(weeklyRays, weeklyZones)
if showWeekly and isNewWeek and not monthlyFiring and not na(close[1])
    drawGap(close[1], open, weeklyColor, toWidth(weeklyWidthIn), toLineStyle(weeklyStyleIn), weeklyRays, weeklyZones)

if isNewMonth
    clearGaps(monthlyRays, monthlyZones)
if showMonthly and isNewMonth and not na(close[1])
    drawGap(close[1], open, monthlyColor, toWidth(monthlyWidthIn), toLineStyle(monthlyStyleIn), monthlyRays, monthlyZones)

// ============================================================
//  Opening Price Lines
//  One model for all four sessions. On the first bar that crosses
//  the session's open time, (re)draw a horizontal ray + label at
//  that bar's open. Terminus pins the right edge to "now" so labels
//  stay on-screen and aligned on every intraday timeframe.
// ============================================================
type Opl
    bool   show
    int    hr
    int    mn
    color  col
    string sty
    int    wid
    string tag
    line   ln = na
    label  lb = na

updateOpl(Opl o) =>
    if o.show and intraday
        // Date components must be read in the SAME timezone we build the timestamp in,
        // otherwise an exchange-vs-selected-tz date roll shifts the open time by a day
        // and the line anchors to the wrong bar (e.g. the new-day open).
        openTs  = timestamp(Timezone, year(time, Timezone), month(time, Timezone), dayofmonth(time, Timezone), o.hr, o.mn, 0)
        crossed = time >= openTs and (na(time[1]) or time[1] < openTs)
        if crossed
            if not na(o.ln)
                line.delete(o.ln)
            if not na(o.lb)
                label.delete(o.lb)
            o.ln := line.new(openTs, open, openTs, open, xloc=xloc.bar_time, color=o.col, style=o.sty, width=o.wid)
            o.lb := label.new(openTs, open, xloc=xloc.bar_time, text=" " + o.tag + " ", color=color.new(color.black, 100), textcolor=color.black, style=label.style_label_left, size=size.normal)

var array<Opl> opls = array.new<Opl>()
if barstate.isfirst
    array.push(opls, Opl.new(mShow,  0,  0, mCol, toLineStyle(mSty), toWidth(mWid), mTag))
    array.push(opls, Opl.new(nShow,  8, 30, nCol, toLineStyle(nSty), toWidth(nWid), nTag))
    array.push(opls, Opl.new(eShow,  9, 30, eCol, toLineStyle(eSty), toWidth(eWid), eTag))
    array.push(opls, Opl.new(aShow, 13, 30, aCol, toLineStyle(aSty), toWidth(aWid), aTag))

for o in opls
    updateOpl(o)

if barstate.islast and intraday
    rightEdge = timenow + 3600000  // now + 1h
    for o in opls
        if not na(o.ln)
            line.set_x2(o.ln, rightEdge)
            label.set_x(o.lb, rightEdge)

// ============================================================
//  Notes (top center)
// ============================================================
var table notesTable = table.new(position.top_center, 1, 2, bgcolor=color.new(color.black, 100), border_width=0)
if barstate.islast
    table.cell(notesTable, 0, 0, text=showTitle ? titleText : "", text_size=size.huge,   text_color=titleColor, text_halign=text.align_center)
    table.cell(notesTable, 0, 1, text=showSub   ? subText   : "", text_size=size.normal, text_color=subColor,   text_halign=text.align_center)

// ============================================================
//  Setup Checklist (top right)
// ============================================================
var table setupTable = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80), border_width=0)

drawCheck(int row, bool isOn, string txt) =>
    if txt != ""
        table.cell(setupTable, 0, row, text=isOn ? "☑" : "☐", text_color=isOn ? color.green : color.silver, text_size=size.normal)
        table.cell(setupTable, 1, row, text=" " + txt + " ", text_color=color.white, text_size=size.normal, text_halign=text.align_left)

if barstate.islast and showSetup
    drawCheck(0, c1On, c1Tx)
    drawCheck(1, c2On, c2Tx)
    drawCheck(2, c3On, c3Tx)
    drawCheck(3, c4On, c4Tx)
    drawCheck(4, c5On, c5Tx)
