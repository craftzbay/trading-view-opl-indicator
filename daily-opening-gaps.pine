//@version=6
indicator("Opening Levels — Gaps + OPL", "OL", overlay=true,
          max_lines_count=500, max_boxes_count=500, max_labels_count=100)

// ============================================================
//  Inputs: General
// ============================================================
gGen = "General"
tzInput = input.string("America/New_York", "Timezone", group=gGen, options=[
     "Exchange",
     "UTC",
     "America/New_York",
     "America/Chicago",
     "America/Denver",
     "America/Los_Angeles",
     "Europe/London",
     "Europe/Berlin",
     "Europe/Moscow",
     "Asia/Dubai",
     "Asia/Kolkata",
     "Asia/Shanghai",
     "Asia/Hong_Kong",
     "Asia/Singapore",
     "Asia/Tokyo",
     "Asia/Ulaanbaatar",
     "Australia/Sydney"],
     tooltip="OPL-ийн open цаг болон HTF gap-ийн өдөр/долоо хоног/сарын хил энэ timezone-оор тооцогдоно. 'Exchange' = графикийн symbol-ийн биржийн timezone.")

// ============================================================
//  Inputs: HTF Opening Gaps
// ============================================================
gHtf = "HTF Opening Gaps"

showMonthly    = input.bool(true,        "", inline="gm", group=gHtf, tooltip="Monthly Opening Gap (previous month close → current month open)")
monthlyName    = input.string("MONTHLY", "", inline="gm", group=gHtf)
monthlyColor   = input.color(#4a148c,    "", inline="gm", group=gHtf)
monthlyStyleIn = input.string("Solid",   "", options=["Solid","Dashed","Dotted"], inline="gm", group=gHtf)
monthlyWidthIn = input.string("1px",     "", options=["1px","2px","3px","4px"],   inline="gm", group=gHtf)

showWeekly     = input.bool(true,        "", inline="gw", group=gHtf, tooltip="Weekly Opening Gap (previous week close → current week open)")
weeklyName     = input.string("WEEKLY",  "", inline="gw", group=gHtf)
weeklyColor    = input.color(#0c3299,    "", inline="gw", group=gHtf)
weeklyStyleIn  = input.string("Solid",   "", options=["Solid","Dashed","Dotted"], inline="gw", group=gHtf)
weeklyWidthIn  = input.string("1px",     "", options=["1px","2px","3px","4px"],   inline="gw", group=gHtf)

showDaily      = input.bool(true,        "", inline="gd", group=gHtf, tooltip="Daily Opening Gap (previous day close → current day open)")
dailyName      = input.string("DAILY",   "", inline="gd", group=gHtf)
dailyColor     = input.color(#006064,    "", inline="gd", group=gHtf)
dailyStyleIn   = input.string("Solid",   "", options=["Solid","Dashed","Dotted"], inline="gd", group=gHtf)
dailyWidthIn   = input.string("1px",     "", options=["1px","2px","3px","4px"],   inline="gd", group=gHtf)

// ============================================================
//  Inputs: Opening Price Lines  (one row each: show | label | color | style | width)
// ============================================================
gOpl = "Opening Price Lines"

mShow = input.bool(true,    "", inline="m", group=gOpl, tooltip="00:00 — Midnight open")
mTag  = input.string("00:00","", inline="m", group=gOpl)
mCol  = input.color(#0c3299,"", inline="m", group=gOpl)
mSty  = input.string("Solid","", options=["Solid","Dashed","Dotted"], inline="m", group=gOpl)
mWid  = input.string("1px",  "", options=["1px","2px","3px","4px","5px"], inline="m", group=gOpl)

nShow = input.bool(true,    "", inline="n", group=gOpl, tooltip="08:30 — New York open")
nTag  = input.string("08:30","", inline="n", group=gOpl)
nCol  = input.color(#0c3299,"", inline="n", group=gOpl)
nSty  = input.string("Solid","", options=["Solid","Dashed","Dotted"], inline="n", group=gOpl)
nWid  = input.string("1px",  "", options=["1px","2px","3px","4px","5px"], inline="n", group=gOpl)

eShow = input.bool(true,    "", inline="e", group=gOpl, tooltip="09:30 — Equities open")
eTag  = input.string("09:30","", inline="e", group=gOpl)
eCol  = input.color(#0c3299,"", inline="e", group=gOpl)
eSty  = input.string("Solid","", options=["Solid","Dashed","Dotted"], inline="e", group=gOpl)
eWid  = input.string("1px",  "", options=["1px","2px","3px","4px","5px"], inline="e", group=gOpl)

aShow = input.bool(false,   "", inline="a", group=gOpl, tooltip="13:30 — Afternoon open")
aTag  = input.string("01:30","", inline="a", group=gOpl)
aCol  = input.color(#0c3299,"", inline="a", group=gOpl)
aSty  = input.string("Solid","", options=["Solid","Dashed","Dotted"], inline="a", group=gOpl)
aWid  = input.string("1px",  "", options=["1px","2px","3px","4px","5px"], inline="a", group=gOpl)

// ============================================================
//  Inputs: HTF Candles  (higher-timeframe candles drawn to the right of price action)
// ============================================================
gHtfC = "HTF Candles"
htfPad       = input.int(30, "Padding from last bar", minval=0, group=gHtfC, tooltip="Bars of gap between live price action and the first HTF block")
htfWidth     = 2  // candle body width in bars (fixed)
htfGap       = 1  // spacing between candles in bars (fixed)
htfBull      = input.color(#808080, "Bull / Bear / Border / Wick", inline="hc", group=gHtfC)
htfBear      = input.color(#000000, "", inline="hc", group=gHtfC)
htfBorderCol = input.color(#000000, "", inline="hc", group=gHtfC)
htfWickCol   = input.color(#000000, "", inline="hc", group=gHtfC)
htfShowLabel = input.bool(true, "Timeframe labels", group=gHtfC)

// Up to 5 HTF sets — each: enable | timeframe | candle count. Uniform "HTFn" labels keep rows aligned.
h1On = input.bool(false, "HTF1      ", inline="s1", group=gHtfC, tooltip="Default: Weekly")
h1Tf = input.timeframe("W",   "", inline="s1", group=gHtfC)
h1N  = input.int(4, "", minval=1, maxval=50, inline="s1", group=gHtfC)
h2On = input.bool(true,  "HTF2      ", inline="s2", group=gHtfC, tooltip="Default: Daily")
h2Tf = input.timeframe("D",   "", inline="s2", group=gHtfC)
h2N  = input.int(1, "", minval=1, maxval=50, inline="s2", group=gHtfC)
h3On = input.bool(true,  "HTF3      ", inline="s3", group=gHtfC, tooltip="Default: 4H")
h3Tf = input.timeframe("240", "", inline="s3", group=gHtfC)
h3N  = input.int(3, "", minval=1, maxval=50, inline="s3", group=gHtfC)
h4On = input.bool(true,  "HTF4      ", inline="s4", group=gHtfC, tooltip="Default: 1H")
h4Tf = input.timeframe("60",  "", inline="s4", group=gHtfC)
h4N  = input.int(5, "", minval=1, maxval=50, inline="s4", group=gHtfC)
h5On = input.bool(false, "HTF5      ", inline="s5", group=gHtfC, tooltip="Default: 15m")
h5Tf = input.timeframe("15",  "", inline="s5", group=gHtfC)
h5N  = input.int(8, "", minval=1, maxval=50, inline="s5", group=gHtfC)

// ============================================================
//  Inputs: Notes (top center)
// ============================================================
gNotes     = "Notes"
showTitle  = input.bool(true,         "", inline="t", group=gNotes)
titleText  = input.string("Title",    "", inline="t", group=gNotes)
titleColor = input.color(#000000,     "", inline="t", group=gNotes)
showSub    = input.bool(true,         "", inline="s", group=gNotes)
subText    = input.string("Subtitle", "", inline="s", group=gNotes)
subColor   = input.color(#000000,     "", inline="s", group=gNotes)

// ============================================================
//  Inputs: Setup Checklist (top right)
// ============================================================
gSetup    = "Setup Checklist"
showSetup = input.bool(true, "Show checklist", group=gSetup)

c1On = input.bool(false,               "", inline="c1", group=gSetup)
c1Tx = input.string("Bias confirmed",  "", inline="c1", group=gSetup)
c2On = input.bool(false,               "", inline="c2", group=gSetup)
c2Tx = input.string("Liquidity taken", "", inline="c2", group=gSetup)
c3On = input.bool(false,               "", inline="c3", group=gSetup)
c3Tx = input.string("FVG aligned",     "", inline="c3", group=gSetup)
c4On = input.bool(false,               "", inline="c4", group=gSetup)
c4Tx = input.string("Entry confirmed", "", inline="c4", group=gSetup)
c5On = input.bool(false,               "", inline="c5", group=gSetup)
c5Tx = input.string("Risk OK",         "", inline="c5", group=gSetup)

// ============================================================
//  Helpers
// ============================================================
toLineStyle(string s) => s == "Dashed" ? line.style_dashed : s == "Dotted" ? line.style_dotted : line.style_solid
toWidth(string s)     => s == "5px" ? 5 : s == "4px" ? 4 : s == "3px" ? 3 : s == "2px" ? 2 : 1

pad2(int n) => (n < 10 ? "0" : "") + str.tostring(n)
// 1-minute session window for an open time, e.g. (8,30) -> "0830-0831:1234567"
oplSession(int hr, int mn) =>
    s = hr * 60 + mn
    e = s + 1
    pad2(int(s / 60)) + pad2(s % 60) + "-" + pad2(int(e / 60)) + pad2(e % 60) + ":1234567"

// Friendly timeframe label: "240" -> "4H", "60" -> "1H", "15" -> "15m", "D"/"W"/"M" as-is
tfLabel(string tf) =>
    num = str.tonumber(tf)
    na(num) ? tf : (int(num) % 60 == 0 ? str.tostring(int(int(num) / 60)) + "H" : str.tostring(int(num)) + "m")

delBoxes(array<box> a) =>
    for b in a
        box.delete(b)
    array.clear(a)

delLines(array<line> a) =>
    for l in a
        line.delete(l)
    array.clear(a)

// ============================================================
//  Time / timezone
// ============================================================
Timezone = tzInput == "Exchange" ? syminfo.timezone : tzInput
intraday = timeframe.isintraday and timeframe.multiplier <= 31

isNewDay   = ta.change(time("1D")) != 0
isNewWeek  = ta.change(time("1W")) != 0
isNewMonth = ta.change(time("1M")) != 0

// ============================================================
//  HTF Opening Gaps
//  Each gap = 2 rays (top/bottom) + a 90%-transparent zone box.
//  Daily gaps accumulate through the week (reset weekly); weekly &
//  monthly keep only the current period.
//  Priority on overlap: MONTHLY > WEEKLY > DAILY.
// ============================================================
clearGaps(array<line> rays, array<box> zones) =>
    for r in rays
        line.delete(r)
    for b in zones
        box.delete(b)
    array.clear(rays)
    array.clear(zones)

drawGap(float prevClose, float openPx, color col, int wid, string sty, array<line> rays, array<box> zones) =>
    if prevClose != openPx
        top = math.max(prevClose, openPx)
        bot = math.min(prevClose, openPx)
        array.push(rays, line.new(bar_index, top, bar_index + 1, top, extend=extend.right, color=col, width=wid, style=sty))
        array.push(rays, line.new(bar_index, bot, bar_index + 1, bot, extend=extend.right, color=col, width=wid, style=sty))
        array.push(zones, box.new(bar_index, top, bar_index + 1, bot, extend=extend.right, bgcolor=color.new(col, 90), border_color=na))

var array<line> dailyRays    = array.new<line>()
var array<box>  dailyZones   = array.new<box>()
var array<line> weeklyRays   = array.new<line>()
var array<box>  weeklyZones  = array.new<box>()
var array<line> monthlyRays  = array.new<line>()
var array<box>  monthlyZones = array.new<box>()

monthlyFiring = showMonthly and isNewMonth
weeklyFiring  = showWeekly  and isNewWeek

if isNewWeek
    clearGaps(dailyRays, dailyZones)
if showDaily and isNewDay and not weeklyFiring and not monthlyFiring and not na(close[1])
    drawGap(close[1], open, dailyColor, toWidth(dailyWidthIn), toLineStyle(dailyStyleIn), dailyRays, dailyZones)

if isNewWeek
    clearGaps(weeklyRays, weeklyZones)
if showWeekly and isNewWeek and not monthlyFiring and not na(close[1])
    drawGap(close[1], open, weeklyColor, toWidth(weeklyWidthIn), toLineStyle(weeklyStyleIn), weeklyRays, weeklyZones)

if isNewMonth
    clearGaps(monthlyRays, monthlyZones)
if showMonthly and isNewMonth and not na(close[1])
    drawGap(close[1], open, monthlyColor, toWidth(monthlyWidthIn), toLineStyle(monthlyStyleIn), monthlyRays, monthlyZones)

// ============================================================
//  Opening Price Lines
//  One model for all four sessions. On the first bar that crosses
//  the session's open time, (re)draw a horizontal ray + label at
//  that bar's open. Terminus pins the right edge to "now" so labels
//  stay on-screen and aligned on every intraday timeframe.
// ============================================================
type Opl
    bool   show
    int    hr
    int    mn
    color  col
    string sty
    int    wid
    string tag
    line   ln = na
    label  lb = na

// Session-open rising edge for one open time. Uses a 1-minute session window in the
// selected timezone → only the real open bar (e.g. 08:30), never a post-gap resume bar.
// Reads t[1] (history), so it MUST be called unconditionally at a fixed site every bar.
oplOpened(int hr, int mn) =>
    t = time(timeframe.period, oplSession(hr, mn), Timezone)
    not na(t) and na(t[1])

// Fixed top-scope call sites — evaluated on every bar (no loop, no conditional).
mEdge = oplOpened(0,  0)
nEdge = oplOpened(8,  30)
eEdge = oplOpened(9,  30)
aEdge = oplOpened(13, 30)

// Drawing only — no history references, so it is safe to call from a loop/conditional.
drawOpl(Opl o, bool opened) =>
    if opened and o.show and intraday
        if not na(o.ln)
            line.delete(o.ln)
        if not na(o.lb)
            label.delete(o.lb)
        // Anchor to the real open bar — no date math, no gap edge cases.
        o.ln := line.new(time, open, time, open, xloc=xloc.bar_time, color=o.col, style=o.sty, width=o.wid)
        o.lb := label.new(time, open, xloc=xloc.bar_time, text=" " + o.tag + " ", color=color.new(color.black, 100), textcolor=color.black, style=label.style_label_left, size=size.normal)

var array<Opl> opls = array.new<Opl>()
if barstate.isfirst
    array.push(opls, Opl.new(mShow,  0,  0, mCol, toLineStyle(mSty), toWidth(mWid), mTag))
    array.push(opls, Opl.new(nShow,  8, 30, nCol, toLineStyle(nSty), toWidth(nWid), nTag))
    array.push(opls, Opl.new(eShow,  9, 30, eCol, toLineStyle(eSty), toWidth(eWid), eTag))
    array.push(opls, Opl.new(aShow, 13, 30, aCol, toLineStyle(aSty), toWidth(aWid), aTag))

drawOpl(array.get(opls, 0), mEdge)
drawOpl(array.get(opls, 1), nEdge)
drawOpl(array.get(opls, 2), eEdge)
drawOpl(array.get(opls, 3), aEdge)

if barstate.islast and intraday
    rightEdge = timenow + 3600000  // now + 1h
    for o in opls
        if not na(o.ln)
            line.set_x2(o.ln, rightEdge)
            label.set_x(o.lb, rightEdge)

// ============================================================
//  HTF Candles
//  Up to 5 higher-timeframe sets, each drawn as boxes (body) + lines
//  (wick) in its own block to the right of price action, left→right.
//  Optional OHLC traces + per-set timeframe label.
// ============================================================
type HtfSet
    bool   show
    string tf
    int    count
    array<float> O
    array<float> H
    array<float> L
    array<float> C

// Accumulate the last `count` HTF candles for one set (newest = forming candle).
collectHtf(HtfSet s, bool isNew, float o, float h, float l, float c) =>
    if s.show
        if isNew
            array.push(s.O, o)
            array.push(s.H, h)
            array.push(s.L, l)
            array.push(s.C, c)
        else if array.size(s.O) > 0
            i = array.size(s.O) - 1
            array.set(s.H, i, math.max(array.get(s.H, i), h))
            array.set(s.L, i, math.min(array.get(s.L, i), l))
            array.set(s.C, i, c)
        // trim to the last `count` candles (while returns void → keeps branch types consistent)
        while array.size(s.O) > s.count
            array.shift(s.O)
            array.shift(s.H)
            array.shift(s.L)
            array.shift(s.C)

// request.security needs simple-string timeframes at top scope → one call per set.
[o1, h1, l1, c1, t1] = request.security(syminfo.tickerid, h1Tf, [open, high, low, close, time], lookahead=barmerge.lookahead_off)
[o2, h2, l2, c2, t2] = request.security(syminfo.tickerid, h2Tf, [open, high, low, close, time], lookahead=barmerge.lookahead_off)
[o3, h3, l3, c3, t3] = request.security(syminfo.tickerid, h3Tf, [open, high, low, close, time], lookahead=barmerge.lookahead_off)
[o4, h4, l4, c4, t4] = request.security(syminfo.tickerid, h4Tf, [open, high, low, close, time], lookahead=barmerge.lookahead_off)
[o5, h5, l5, c5, t5] = request.security(syminfo.tickerid, h5Tf, [open, high, low, close, time], lookahead=barmerge.lookahead_off)

var s1 = HtfSet.new(h1On, h1Tf, h1N, array.new<float>(), array.new<float>(), array.new<float>(), array.new<float>())
var s2 = HtfSet.new(h2On, h2Tf, h2N, array.new<float>(), array.new<float>(), array.new<float>(), array.new<float>())
var s3 = HtfSet.new(h3On, h3Tf, h3N, array.new<float>(), array.new<float>(), array.new<float>(), array.new<float>())
var s4 = HtfSet.new(h4On, h4Tf, h4N, array.new<float>(), array.new<float>(), array.new<float>(), array.new<float>())
var s5 = HtfSet.new(h5On, h5Tf, h5N, array.new<float>(), array.new<float>(), array.new<float>(), array.new<float>())

// Draw order = smallest TF nearest price → largest TF furthest right (push reversed).
var array<HtfSet> htfSets = array.new<HtfSet>()
if barstate.isfirst
    array.push(htfSets, s5)
    array.push(htfSets, s4)
    array.push(htfSets, s3)
    array.push(htfSets, s2)
    array.push(htfSets, s1)

collectHtf(s1, ta.change(t1) != 0, o1, h1, l1, c1)
collectHtf(s2, ta.change(t2) != 0, o2, h2, l2, c2)
collectHtf(s3, ta.change(t3) != 0, o3, h3, l3, c3)
collectHtf(s4, ta.change(t4) != 0, o4, h4, l4, c4)
collectHtf(s5, ta.change(t5) != 0, o5, h5, l5, c5)

var array<box>   htfBodies = array.new<box>()
var array<line>  htfWicks  = array.new<line>()
var array<label> htfLbls   = array.new<label>()

if barstate.islast
    delBoxes(htfBodies)
    delLines(htfWicks)
    for lb in htfLbls
        label.delete(lb)
    array.clear(htfLbls)

    step   = htfWidth + htfGap
    setGap = 3                       // bars between consecutive HTF blocks
    base   = bar_index + htfPad
    labXs  = array.new<int>()        // label x-centres, drawn after the loop at one level
    labTxt = array.new<string>()
    float gTop = na                  // global highest high across all blocks
    for s in htfSets
        // stop if we're out of future-draw room (Pine caps lines/boxes at ~+500 bars)
        if s.show and array.size(s.O) > 0 and base - bar_index < 470
            n        = array.size(s.O)
            maxFit   = math.max(1, int((490 - (base - bar_index)) / step))
            drawN    = math.min(n, maxFit)
            startIdx = n - drawN
            for i = 0 to drawN - 1
                src   = startIdx + i
                o = array.get(s.O, src)
                h = array.get(s.H, src)
                l = array.get(s.L, src)
                c = array.get(s.C, src)
                left  = base + i * step
                right = left + htfWidth
                mid   = int((left + right) / 2)
                col   = c >= o ? htfBull : htfBear
                array.push(htfWicks, line.new(mid, h, mid, l, xloc=xloc.bar_index, color=htfWickCol, width=1))
                array.push(htfBodies, box.new(left, math.max(o, c), right, math.min(o, c), xloc=xloc.bar_index, bgcolor=col, border_color=htfBorderCol))
                gTop := na(gTop) ? h : math.max(gTop, h)

            lLeft = base + (drawN - 1) * step
            if htfShowLabel
                array.push(labXs, int((base + lLeft + htfWidth) / 2))
                array.push(labTxt, tfLabel(s.tf))

            base := lLeft + htfWidth + setGap

    // all block labels on one horizontal level (the global top), so they line up
    if htfShowLabel and not na(gTop)
        for k = 0 to array.size(labXs) - 1
            array.push(htfLbls, label.new(array.get(labXs, k), gTop, text=array.get(labTxt, k), xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_down, color=color.new(color.gray, 70), textcolor=chart.fg_color, size=size.small))

// ============================================================
//  Notes (top center)
// ============================================================
var table notesTable = table.new(position.top_center, 1, 2, bgcolor=color.new(color.black, 100), border_width=0)
if barstate.islast
    table.cell(notesTable, 0, 0, text=showTitle ? titleText : "", text_size=size.huge,   text_color=titleColor, text_halign=text.align_center)
    table.cell(notesTable, 0, 1, text=showSub   ? subText   : "", text_size=size.normal, text_color=subColor,   text_halign=text.align_center)

// ============================================================
//  Setup Checklist (top right)
// ============================================================
var table setupTable = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80), border_width=0)

drawCheck(int row, bool isOn, string txt) =>
    if txt != ""
        table.cell(setupTable, 0, row, text=isOn ? "☑" : "☐", text_color=isOn ? color.green : color.silver, text_size=size.normal)
        table.cell(setupTable, 1, row, text=" " + txt + " ", text_color=color.white, text_size=size.normal, text_halign=text.align_left)

if barstate.islast and showSetup
    drawCheck(0, c1On, c1Tx)
    drawCheck(1, c2On, c2Tx)
    drawCheck(2, c3On, c3Tx)
    drawCheck(3, c4On, c4Tx)
    drawCheck(4, c5On, c5Tx)
